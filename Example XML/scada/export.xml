	<UAVariable NodeId="ns=1;s=SYSTEM.LIBRARY.ATVISE.RESOURCES/export" BrowseName="1:export" DataType="XmlElement" AccessLevel="7" UserAccessLevel="7" Historizing="true">
		<DisplayName Locale="en">export</DisplayName>
