<script>
  <metadata>
    <priority>0</priority>
  </metadata>
  <parameter name="request" type="http.request" trigger="false" relative="false" value=""/>
  <parameter name="response" type="http.response" trigger="false" relative="false" value=""/>
  <parameter name="session" type="http.session" trigger="false" relative="false" value=""/>
  <parameter name="allowForm" type="boolean" trigger="false" relative="false" value="false"/>
  <parameter name="allowHTTP" type="boolean" trigger="false" relative="false" value="false"/>
  <code><![CDATA[/*
This script shows an example of what could happen when the authorization fails.
Please feel free to modify this script to fit your own requirements.

http and https servers are to define under AGENT.WEBACCESS .
They shall be named http1, http2, http3, ... and https1, https2, https3, ...
*/

var authentication = session.authentication;
var status = session.status;
var host = session.host.name;
var port = session.host.port;
var realm = session.realm;

var page = "<!DOCTYPE HTML PUBLIC \"-//IETF//DTD HTML 2.0//EN\">\n" +
	"<html><head>\n" +
	"<title>401  Unauthorized</title>\n" +
	"</head><body>\n" +
	"<h1>Unauthorized</h1>\n";

function getServerAttributes(server) {
	var retVal = {};
	var attributes = server.browse({
		nodeClass: Ua.NodeClass.VARIABLE
	});

	for (var i = 0; i < attributes.length; ++i) {
		if (attributes[i].node.browsename == "authentication") retVal["authentication"] = attributes[i].node.value;
		if (attributes[i].node.browsename == "port") retVal["port"] = attributes[i].node.value;
		if (attributes[i].node.browsename == "state") retVal["state"] = attributes[i].node.value;
	}
	return retVal;
}

/**
 * 
 * @param loginMethod
 * @returns {boolean} (loginMethod != authentication)
 */
function isValidLoginMethod(loginMethod) {
	if (allowForm)
		return loginMethod == "basic" || loginMethod == "digest" || loginMethod == "form";
	else
		return loginMethod == "basic" || loginMethod == "digest";
}


/**
 * @returns {Array} (returns alternative addresses to connect with)
 */
function getServerList() {
	var n = 1;
	var ret = [];
	var servers = [];

	var serverNode = Ua.findNode(base);
	var serverExist = Ua.Status(serverNode) != Ua.Status.BADNODEIDUNKNOWN;

	var isHTTP = serverNode.result.typeDefinition == "ns=1;s=ObjectTypes.ATVISE.WebAccess.Http"
	var isHTTPs = serverNode.result.typeDefinition == "ns=1;s=ObjectTypes.ATVISE.WebAccess.Https"

	if (isHTTP || (isHTTPs && allowHTTP)) {
		servers = Ua.findNode("AGENT.WEBACCESS").result.browse({
			nodeClass: Ua.NodeClass.OBJECT,
			recursive: true
		});
	} else {
		servers = Ua.findNode("AGENT.WEBACCESS").result.browse({
			nodeClass: Ua.NodeClass.OBJECT,
			typeDefinition: serverNode.result.typeDefinition,
			recursive: true
		});
	}

	for (var s in servers.result) {
		if (servers.result[s].node.nodeId.address != serverNode.result.nodeId.address) {
			var attributes = getServerAttributes(servers.result[s].node);
			if (attributes && attributes["authentication"] && isValidLoginMethod(attributes["authentication"]) && attributes["port"]) {
				var http = (servers.result[s].node.typeDefinition == "ns=1;s=ObjectTypes.ATVISE.WebAccess.Https") ? "https" : "http";
				ret[n++] = {"url": http + "://" + host + ":" + attributes["port"], "state": attributes["state"]};
			}
		}
	}
	return ret;
}

if (authentication == "basic") {
	
	//Implement if needed
	
} else if (authentication == "digest") {
	
	//Implement if needed
	
} else if (authentication == "ntlm" || authentication == "negotiate") {
	
	if (status == "InvalidUserOrPassword") {
		page += "<p>Either you are not authorized to access the document requested, or your browser doesn't understand how to supply the credentials required.</p>\n";
	} else if (status == "AuthenticationServiceError") {
		page += "<p>The service verifying your credentials may be temporarily unavailable.</p>\n";

		var serverlist = getServerList();
		
		if (serverlist) {
			page += "<p>You can use the following alternative addresses to connect with:</p>\n";
			for (var s in serverlist) {
				var state = (serverlist[s].state == 0) ? "Online" : "Offline";
				page += "<a href=\"" + serverlist[s].url + "\">" + serverlist[s].url + "</a> (State: " + state + ")<br/>\n";
			}
			page += "<p><a href=\"#\" onclick=\"window.location.reload(true);\">Refresh page</a></p>\n";
		}
		
	} else if (status == "AuthenticationSecurityError") {
		page += "<p>This server could not verify that you are authorized to access the document requested.</p>\n";
		page += "<p>Either your browser doesn't understand how to supply the credentials required or your security settings are incorrect.</p>\n";
		page += "<p>Check the Security Policies 'Local Policies > Security Options > Network Security LAN Manager authentication level' ";
		page += "and select 'Send LM & NTLM - use NTLMv2 session security if negotiated'.</p>\n";
	}
	
}

page += "<hr>\n" +
	"<address>atvise Server at " + escape(host) + ":" + port + "</address>\n" +
	"</body></html>";

response.write(page);

return;]]]]><![CDATA[></code>
